pipeline {
    agent any

    environment {
        // Git
        REPO_URL          = 'https://github.com/PCS-Indonesia/brifms_23-05-ms-api-go'
        GIT_CREDENTIAL_ID = 'github-token'
        BRANCH            = 'master'

        // Docker
        DOCKER_CREDENTIAL_ID = 'dockerhub-creds'
        IMAGE_NAME           = 'devopspcs/ms-api-go'
        IMAGE_TAG            = "${BUILD_NUMBER}"

        // SSH & Remote servers
        SSH_CREDENTIAL_ID = 'jenkins-ssh'
        REMOTE_USER       = 'jenkins'
        REMOTE_DIR        = '/home/adminpcs/new-ms-api'
        REMOTE_HOSTS      = '10.184.20.115 10.184.20.116 10.10.2.103'

        // Notification
        GOOGLE_CHAT_WEBHOOK = 'https://chat.googleapis.com/v1/spaces/AAAAwBoByKI/messages?key=AIzaSyDdI0hCZtE6vySjMm-WEfRq3CPzqKqqsHI&token=uPN5Q-oGuL1m-n3klV9gnFP8-qroUrCrJTDoUt-BubE'
    }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "🔄 Checking out source code..."
                git branch: env.BRANCH,
                    credentialsId: env.GIT_CREDENTIAL_ID,
                    url: env.REPO_URL
            }
        }

        stage('Build Image') {
            steps {
                echo "🔨 Building Docker image..."
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest"
            }
        }

        stage('Push to Docker Hub') {
            steps {
                echo "📤 Pushing image to Docker Hub..."
                withCredentials([usernamePassword(
                    credentialsId: env.DOCKER_CREDENTIAL_ID,
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin"
                    sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                    sh "docker push ${IMAGE_NAME}:latest"
                }
            }
        }

        stage('Deploy to Production') {
            steps {
                script {
                    echo "🚀 Deploying to production servers..."
                    sshagent(credentials: [env.SSH_CREDENTIAL_ID]) {
                        def hosts = env.REMOTE_HOSTS.split()
                        for (h in hosts) {
                            echo "📦 Deploying to ${h}"
                            sh """
                                ssh -o StrictHostKeyChecking=no ${env.REMOTE_USER}@${h} \
                                'cd ${env.REMOTE_DIR} && \
                                sudo docker-compose pull && \
                                sudo docker-compose up -d'
                            """
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:${IMAGE_TAG} || true"
            cleanWs()
        }
        success {
            script {
                sendNotification("✅ Build & Deploy Successful!")
            }
        }
        failure {
            script {
                sendNotification("❌ Build & Deploy Failed!")
            }
        }
    }
}

def sendNotification(String messageText) {
    wrap([$class: 'BuildUser']) {
        def user = env.BUILD_USER ?: 'unknown'
        def message = [
            'cards': [[
                'header': [
                    'title': "(Production) ms-api-go",
                    'subtitle': "Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]'",
                    'imageUrl': "https://bucket.pcsindonesia.com/icon/m3s-icon.png",
                    'imageStyle': "IMAGE"
                ],
                'sections': [[
                    'widgets': [
                        ['textParagraph': ['text': messageText]],
                        ['keyValue': ['topLabel': "Job Name", 'content': env.JOB_NAME]],
                        ['keyValue': ['topLabel': "Build URL", 'content': env.BUILD_URL]],
                        ['keyValue': ['topLabel': "Triggered by", 'content': user]],
                        ['keyValue': ['topLabel': "Image", 'content': "${env.IMAGE_NAME}:${env.IMAGE_TAG}"]]
                    ]
                ]]
            ]]
        ]

        try {
            httpRequest(
                httpMode: 'POST',
                contentType: 'APPLICATION_JSON',
                requestBody: groovy.json.JsonOutput.toJson(message),
                url: env.GOOGLE_CHAT_WEBHOOK
            )
        } catch (Exception e) {
            echo "Failed to send notification: ${e.message}"
        }
    }
}
