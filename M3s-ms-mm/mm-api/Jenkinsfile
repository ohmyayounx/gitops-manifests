pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: agent
spec:
  containers:
    - name: tools
      image: alpine:3.19
      command: ['sleep']
      args: ['infinity']
      resources:
        requests:
          memory: "128Mi"
          cpu: "100m"
        limits:
          memory: "512Mi"
          cpu: "500m"
    - name: docker
      image: docker:27-cli
      command: ['sleep']
      args: ['infinity']
      volumeMounts:
        - name: docker-sock
          mountPath: /var/run/docker.sock
    - name: kubectl
      image: bitnami/kubectl:latest
      command: ['sleep']
      args: ['infinity']
  volumes:
    - name: docker-sock
      hostPath:
        path: /var/run/docker.sock
'''
        }
    }

    parameters {
        string(name: 'APP_VERSION', defaultValue: '1.0.0', description: 'Application Version')
    }

    environment {
        // Git
        REPO_URL          = 'https://github.com/PCS-Indonesia/brifms_10-01-mm-api-go.git'
        GIT_CREDENTIAL_ID = 'github-token'
        BRANCH            = 'dev'

        // Docker
        DOCKER_IMAGE         = 'devopspcs/mm-api-go'
        DOCKER_CREDENTIAL_ID = 'dockerhub-auth'

        // Vault
        VAULT_ADDR                  = 'http://10.184.20.4:8200'
        VAULT_SECRET_PATH           = 'development/data/m3s/api/mm-api/env'
        VAULT_SERVICE_ACCOUNT_PATH  = 'development/data/m3s/api/mm-api/service_account'
        VAULT_CREDENTIAL            = 'vault-auth-development'
        SERVICE_ACCOUNT_FILE        = 'service_account_credential.json'

        // Remote K3s Development Server
        REMOTE_USER       = 'tioyan'
        REMOTE_HOST       = '139.180.191.232'
        REMOTE_DIR        = '/home/tioyan/workspaces/m3s/k3s-mm-api'
        NAMESPACE         = 'mm-api'

        // Notification
        GOOGLE_CHAT_WEBHOOK = 'https://chat.googleapis.com/v1/spaces/AAAAszcp4X0/messages?key=AIzaSyDdI0hCZtE6vySjMm-WEfRq3CPzqKqqsHI&token=UwTHtNdi8z_jCatjQwkOuA9vXq3yn0dSsi8oR9Iu4QY'
    }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 Cloning repository..."
                checkout scmGit(
                    branches: [[name: env.BRANCH]],
                    userRemoteConfigs: [[url: env.REPO_URL, credentialsId: env.GIT_CREDENTIAL_ID]]
                )
            }
        }

        stage('Build Docker Image') {
            steps {
                container('docker') {
                    script {
                        def imageName = "${env.DOCKER_IMAGE}:${params.APP_VERSION}"

                        echo "🔨 Building Docker Image: ${imageName}"
                        sh "docker build -f Dockerfile.sample -t ${imageName} ."

                        // Import ke K3s containerd (supaya pod bisa pakai tanpa pull dari registry)
                        sh "docker save ${imageName} | k3s ctr images import -"

                        echo "✅ Image ready: ${imageName}"
                    }
                }
            }
        }

        stage('Fetch Secrets from Vault') {
            steps {
                container('tools') {
                    script {
                        echo "🔐 Fetching secrets from Vault..."

                        withCredentials([usernamePassword(
                            credentialsId: env.VAULT_CREDENTIAL,
                            usernameVariable: 'VAULT_USER',
                            passwordVariable: 'VAULT_PASS'
                        )]) {
                            sh 'apk add --no-cache curl jq > /dev/null 2>&1'

                            sh """
                                VAULT_TOKEN=\$(curl -sk --request POST \
                                    --header "Content-Type: application/json" \
                                    --data '{"password": "'\${VAULT_PASS}'"}' \
                                    ${VAULT_ADDR}/v1/auth/userpass/login/\${VAULT_USER} | \
                                    jq -r '.auth.client_token')

                                if [ -z "\${VAULT_TOKEN}" ] || [ "\${VAULT_TOKEN}" = "null" ]; then
                                    echo "ERROR: Failed to get Vault token"
                                    exit 1
                                fi
                                echo "✅ Vault token obtained"

                                curl -sk --header "X-Vault-Token: \${VAULT_TOKEN}" \
                                    ${VAULT_ADDR}/v1/${VAULT_SERVICE_ACCOUNT_PATH} | \
                                    jq -r '.data.data.content' \
                                    > ${WORKSPACE}/${SERVICE_ACCOUNT_FILE}

                                echo "✅ Service account fetched"

                                curl -sk --header "X-Vault-Token: \${VAULT_TOKEN}" \
                                    ${VAULT_ADDR}/v1/${VAULT_SECRET_PATH} | \
                                    jq -r '.data.data | to_entries[] | "\\(.key)=\\(.value)"' \
                                    > ${WORKSPACE}/mm-api-env.txt

                                echo "✅ Env secrets fetched"
                            """
                        }

                        sh "wc -l ${WORKSPACE}/mm-api-env.txt"
                    }
                }
            }
        }

        stage('Deploy to K3s Development') {
            steps {
                container('kubectl') {
                    script {
                        echo "🚀 Deploying to K3s development server..."

                        // Karena kubectl container punya akses ke K3s cluster lokal,
                        // deploy langsung tanpa SSH (kalau deploy ke cluster yang sama)
                        // Atau SSH ke remote jika cluster berbeda

                        sh """
                            kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                            kubectl create secret generic mm-api-env \
                                --namespace=${NAMESPACE} \
                                --from-env-file=${WORKSPACE}/mm-api-env.txt \
                                --dry-run=client -o yaml | kubectl apply -f -

                            kubectl create secret generic mm-api-gcp-credentials \
                                --namespace=${NAMESPACE} \
                                --from-file=service_account_credential.json=${WORKSPACE}/${SERVICE_ACCOUNT_FILE} \
                                --dry-run=client -o yaml | kubectl apply -f -

                            kubectl apply -f ${WORKSPACE}/02-deployment.yaml 2>/dev/null || true
                            kubectl apply -f ${WORKSPACE}/03-service.yaml 2>/dev/null || true
                            kubectl apply -f ${WORKSPACE}/04-ingress.yaml 2>/dev/null || true

                            kubectl set image deployment/mm-api \
                                mm-api=${DOCKER_IMAGE}:${APP_VERSION} \
                                -n ${NAMESPACE} || true

                            kubectl rollout status deployment/mm-api \
                                -n ${NAMESPACE} --timeout=120s
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "✅ Build & Deploy successful: ${env.DOCKER_IMAGE}:${params.APP_VERSION}"
        }
        failure {
            echo "❌ Build & Deploy failed!"
        }
    }
}
