pipeline {
    agent any

    parameters {
        string(name: 'APP_VERSION', defaultValue: '1.0.0', description: 'Application Version')
    }

    environment {
        // Git
        REPO_URL          = 'https://github.com/PCS-Indonesia/brifms_23-05-ms-api-go.git'
        GIT_CREDENTIAL_ID = 'github-token'
        BRANCH            = 'dev'

        // Docker
        DOCKER_IMAGE         = 'devopspcs/ms-api-go'
        DOCKER_CREDENTIAL_ID = 'dockerhub-auth'

        // Vault
        VAULT_ADDR                  = 'http://10.184.20.4:8200'
        VAULT_SECRET_PATH           = 'development/data/m3s/api/ms-api/env'
        VAULT_SERVICE_ACCOUNT_PATH  = 'development/data/m3s/api/ms-api/service_account_credential'
        VAULT_CREDENTIAL            = 'vault-auth-development'
        SERVICE_ACCOUNT_FILE        = 'service_account_credential.json'

        // Remote K3s Development Server
        SSH_CREDENTIAL_ID = 'tioyan'
        REMOTE_USER       = 'tioyan'
        REMOTE_HOST       = '139.180.191.232'
        REMOTE_DIR        = '/home/tioyan/workspaces/m3s/k3s-ms-api'
        NAMESPACE         = 'ms-api'

        // Notification
        GOOGLE_CHAT_WEBHOOK = 'https://chat.googleapis.com/v1/spaces/AAAAszcp4X0/messages?key=AIzaSyDdI0hCZtE6vySjMm-WEfRq3CPzqKqqsHI&token=UwTHtNdi8z_jCatjQwkOuA9vXq3yn0dSsi8oR9Iu4QY'
    }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 Cloning repository..."
                checkout scmGit(
                    branches: [[name: env.BRANCH]],
                    userRemoteConfigs: [[url: env.REPO_URL, credentialsId: env.GIT_CREDENTIAL_ID]]
                )
            }
        }

        stage('Build and Push Docker Image') {
            steps {
                script {
                    def imageName = "${env.DOCKER_IMAGE}:${params.APP_VERSION}"
                    def latestImageName = "${env.DOCKER_IMAGE}:latest"

                    withCredentials([usernamePassword(
                        credentialsId: env.DOCKER_CREDENTIAL_ID,
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        echo "🔑 Login into Docker Hub"
                        sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                    }

                    echo "🔨 Building Docker Image: ${imageName}"
                    sh "DOCKER_BUILDKIT=1 docker build -f Dockerfile.sample -t ${imageName} ."
                    // sh "docker tag ${imageName} ${latestImageName}"

                    echo "📤 Pushing to Docker Hub"
                    sh "docker push ${imageName}"
                    // sh "docker push ${latestImageName}"
                }
            }
        }

        stage('Fetch Secrets from Vault') {
            steps {
                script {
                    echo "🔐 Fetching secrets from Vault..."

                    def vaultAddr = env.VAULT_ADDR
                    def vaultSecretPath = env.VAULT_SECRET_PATH
                    def vaultServiceAccountPath = env.VAULT_SERVICE_ACCOUNT_PATH
                    def serviceAccountFile = env.SERVICE_ACCOUNT_FILE
                    def workspace = env.WORKSPACE

                    withCredentials([usernamePassword(
                        credentialsId: env.VAULT_CREDENTIAL,
                        usernameVariable: 'VAULT_USER',
                        passwordVariable: 'VAULT_PASS'
                    )]) {
                        // Install jq if not available
                        sh 'which jq || (apt-get update -qq && apt-get install -y -qq jq > /dev/null 2>&1)'

                        sh """
                            # Login ke Vault
                            VAULT_TOKEN=\$(curl -sk --request POST \
                                --header "Content-Type: application/json" \
                                --data '{"password": "'\$VAULT_PASS'"}' \
                                ${vaultAddr}/v1/auth/userpass/login/\$VAULT_USER | \
                                jq -r '.auth.client_token')

                            if [ -z "\$VAULT_TOKEN" ] || [ "\$VAULT_TOKEN" = "null" ]; then
                                echo "ERROR: Failed to get Vault token"
                                exit 1
                            fi
                            echo "✅ Vault token obtained"

                            # Fetch service account
                            curl -sk --header "X-Vault-Token: \$VAULT_TOKEN" \
                                ${vaultAddr}/v1/${vaultServiceAccountPath} | \
                                jq -r '.data.data.content' \
                                > ${workspace}/${serviceAccountFile}

                            echo "✅ Service account fetched"
                            cat ${workspace}/${serviceAccountFile} | head -3

                            # Fetch env secrets
                            curl -sk --header "X-Vault-Token: \$VAULT_TOKEN" \
                                ${vaultAddr}/v1/${vaultSecretPath} | \
                                jq -r '.data.data | to_entries[] | "\\(.key)=\\(.value)"' \
                                > ${workspace}/ms-api-env.txt

                            echo "✅ Env secrets fetched"
                        """
                    }

                    echo "✅ Secrets fetched successfully"
                    sh "wc -l ${env.WORKSPACE}/ms-api-env.txt"
                }
            }
        }

        stage('Deploy to K3s Development') {
            steps {
                script {
                    echo "🚀 Deploying to K3s development server..."

                    def remoteUser = env.REMOTE_USER
                    def remoteHost = env.REMOTE_HOST
                    def remoteDir = env.REMOTE_DIR
                    def namespace = env.NAMESPACE
                    def dockerImage = env.DOCKER_IMAGE
                    def appVersion = params.APP_VERSION
                    def serviceAccountFile = env.SERVICE_ACCOUNT_FILE
                    def workspace = env.WORKSPACE

                    sshagent(credentials: [env.SSH_CREDENTIAL_ID]) {
                        sh """
                            scp -o StrictHostKeyChecking=no \
                                ${workspace}/ms-api-env.txt \
                                ${workspace}/${serviceAccountFile} \
                                ${remoteUser}@${remoteHost}:${remoteDir}/
                        """

                        // Create dockerhub pull secret - write credentials to temp file to avoid shell escaping issues
                        withCredentials([usernamePassword(
                            credentialsId: env.DOCKER_CREDENTIAL_ID,
                            usernameVariable: 'DOCKER_USER',
                            passwordVariable: 'DOCKER_PASS'
                        )]) {
                            // Write password to file to avoid shell special char issues
                            writeFile file: "${workspace}/docker-pass.txt", text: env.DOCKER_PASS
                            sh """
                                scp -o StrictHostKeyChecking=no \
                                    ${workspace}/docker-pass.txt \
                                    ${remoteUser}@${remoteHost}:${remoteDir}/

                                ssh -o StrictHostKeyChecking=no ${remoteUser}@${remoteHost} '
                                    kubectl create namespace ${namespace} --dry-run=client -o yaml | kubectl apply -f -

                                    PASS=\$(cat ${remoteDir}/docker-pass.txt)
                                    kubectl create secret docker-registry dockerhub-pull \
                                        --namespace=${namespace} \
                                        --docker-server=https://index.docker.io/v1/ \
                                        --docker-username=\$DOCKER_USER \
                                        --docker-password="\$PASS" \
                                        --dry-run=client -o yaml | kubectl apply -f -

                                    rm -f ${remoteDir}/docker-pass.txt
                                '
                            """
                        }

                        sh """
                            ssh -o StrictHostKeyChecking=no ${remoteUser}@${remoteHost} '
                                cd ${remoteDir}

                                kubectl create secret generic ms-api-env \
                                    --namespace=${namespace} \
                                    --from-env-file=${remoteDir}/ms-api-env.txt \
                                    --dry-run=client -o yaml | kubectl apply -f -

                                kubectl create secret generic ms-api-gcp-credentials \
                                    --namespace=${namespace} \
                                    --from-file=service_account_credential.json=${remoteDir}/${serviceAccountFile} \
                                    --dry-run=client -o yaml | kubectl apply -f -

                                kubectl apply -f ${remoteDir}/02-deployment.yaml
                                kubectl apply -f ${remoteDir}/03-service.yaml
                                kubectl apply -f ${remoteDir}/04-ingress.yaml

                                kubectl set image deployment/ms-api \
                                    ms-api=${dockerImage}:${appVersion} \
                                    -n ${namespace}

                                kubectl rollout status deployment/ms-api \
                                    -n ${namespace} --timeout=120s

                                rm -f ${remoteDir}/ms-api-env.txt
                            '
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            sh "docker rmi ${env.DOCKER_IMAGE}:${params.APP_VERSION} || true"
            cleanWs()
        }
        success {
            echo "✅ Build & Deploy successful: ${env.DOCKER_IMAGE}:${params.APP_VERSION}"
            script { sendNotification("✅ Build & Deploy to K3s Successful!") }
        }
        failure {
            echo "❌ Build & Deploy failed!"
            script { sendNotification("❌ Build & Deploy Failed!") }
        }
    }
}

def sendNotification(String messageText) {
    def webhook = env.GOOGLE_CHAT_WEBHOOK
    def image = "${env.DOCKER_IMAGE}:${params.APP_VERSION}"
    def jobName = env.JOB_NAME
    def buildNumber = env.BUILD_NUMBER

    sh """
        curl -s -X POST \
            -H 'Content-Type: application/json' \
            -d '{"cards": [{"header": {"title": "(Development-K3s) ms-api-go", "subtitle": "Job ${jobName} [${buildNumber}]"}, "sections": [{"widgets": [{"textParagraph": {"text": "${messageText}"}}, {"keyValue": {"topLabel": "Image", "content": "${image}"}}]}]}]}' \
            '${webhook}' || true
    """
}
